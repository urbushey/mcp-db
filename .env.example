# Directory where .sqlite files are stored
DATA_DIR=./data

# Logging
LOG_LEVEL=normal          # verbose | normal | off
LOG_PATH=./logs/mcp.log

# MCP transport (stdio preserves current behavior; http enables local streamable MCP)
MCP_TRANSPORT=stdio

# Local streamable HTTP MCP server settings (used when MCP_TRANSPORT=http)
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3001
MCP_HTTP_PATH=/mcp
