# Directory where .sqlite files are stored
DATA_DIR=./data

# Logging
LOG_LEVEL=normal          # verbose | normal | off
LOG_PATH=./logs/mcp.log

# MCP transport
MCP_TRANSPORT=stdio       # stdio for local Claude Desktop / Code, http for remote MCP

# Streamable HTTP MCP server settings (used when MCP_TRANSPORT=http)
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3001
MCP_HTTP_PATH=/mcp
PUBLIC_BASE_URL=http://127.0.0.1:3001

# Remote auth (required for Claude-compatible hosted MCP)
AUTH_REQUIRED=false
OAUTH_ISSUER=https://your-workos-issuer.example.com
OAUTH_AUDIENCE=http://127.0.0.1:3001
# OAUTH_JWKS_URL=https://your-workos-issuer.example.com/.well-known/jwks.json
