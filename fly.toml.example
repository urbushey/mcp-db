# Copy to fly.toml after choosing an app name and region.
# This is scaffold only: the current server is stdio-only, so a public Fly HTTP service
# is blocked on the remote transport work tracked in issue #10.

app = "instant-db-staging"
primary_region = "ewr"
kill_signal = "SIGINT"
kill_timeout = "30s"

[build]
  dockerfile = "Dockerfile"

[env]
  DATA_DIR = "/data"
  LOG_PATH = "/data/logs/mcp.log"
  LOG_LEVEL = "normal"
  MCP_TRANSPORT = "http"
  PORT = "3000"
  HOST = "0.0.0.0"
  MCP_HTTP_PATH = "/mcp"

# Uncomment once the app actually binds an HTTP MCP endpoint.
# [http_service]
#   internal_port = 3000
#   force_https = true
#   auto_stop_machines = "stop"
#   auto_start_machines = true
#   min_machines_running = 0
#   processes = ["app"]
#
#   [[http_service.checks]]
#     grace_period = "15s"
#     interval = "30s"
#     method = "HEAD"
#     timeout = "5s"
#     path = "/mcp"
#     protocol = "http"

[mounts]
  source = "instant_db_data"
  destination = "/data"
